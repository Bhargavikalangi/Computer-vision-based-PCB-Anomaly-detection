# ══════════════════════════════════════════
#   PCB Vision — .gitignore
# ══════════════════════════════════════════

# ── Python / Backend ──────────────────────
backend/venv/
backend/__pycache__/
backend/**/__pycache__/
backend/**/*.pyc
backend/**/*.pyo
backend/**/*.pyd
backend/.env
backend/*.egg-info/
backend/dist/
backend/build/
backend/.pytest_cache/
backend/.mypy_cache/

# ── Uploads & Generated Files ─────────────
backend/uploads/
backend/results/
backend/models/*.pt
backend/models/*.pth
backend/models/*.onnx
backend/logs/
*.log

# ── Frontend / Node ───────────────────────
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*

# ── Database ──────────────────────────────
*.sql.bak
*.dump
postgres-data/

# ── OS Files ──────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# ── IDE / Editor ──────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace
.history/

# ── Docker ────────────────────────────────
.docker/

# ── Misc ──────────────────────────────────
*.zip
*.tar.gz
*.rar
.env
.env.*
!.env.example
